# 复制本文件为 .env 后再填入真实值；.env 已经在 .gitignore 里，不会被提交。
#
# OPENAI_API_KEY:    兼容 OpenAI 协议的鉴权 token
# OPENAI_BASE_URL:   完整的 chat completions endpoint URL（含 /v1/chat/completions 等路径）
# OPENAI_MODEL_NAME: 实际使用的模型名

OPENAI_API_KEY=sk-replace-me
OPENAI_BASE_URL=https://api.openai.com/v1/chat/completions
OPENAI_MODEL_NAME=gpt-4o
